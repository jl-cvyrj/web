<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Рэдагаваць трэніроўку</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="container">
  <h1>✏️ Рэдагаванне</h1>

  <form action="/update/<%= item.id %>" method="POST" class="form">
    <div class="form-group">
      <label>Назва:</label>
      <input type="text" name="name" value="<%= item.name %>" required>
    </div>

    <div class="form-group">
      <label>Апісанне:</label>
      <textarea name="description" rows="3" required><%= item.description %></textarea>
    </div>

    <div class="form-actions">
      <button type="submit" class="save-btn">Захаваць</button>
      <button type="button" class="cancel-btn" onclick="location.href='/'">Адмяніць</button>
    </div>
  </form>
</div>
</body>
</html>